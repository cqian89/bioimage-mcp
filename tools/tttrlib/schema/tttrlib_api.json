{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tttrlib API Schema",
  "description": "Curated API surface for tttrlib integration with bioimage-mcp",
  "version": "0.1.0",
  "upstream_version": "0.25.0",
  "parity_inventory": "tools/tttrlib/schema/tttrlib_coverage.json",
  "parity_source": "tttrlib_coverage.json",
  "generated_from": "tttrlib documentation and source introspection",
  "functions": {
    "tttrlib.TTTR": {
      "summary": "Open a TTTR file and return a reference",
      "params": {
        "filename": {
          "type": "string",
          "required": true,
          "description": "Path to TTTR file"
        },
        "container_type": {
          "type": "string",
          "required": false,
          "enum": [
            "PTU",
            "HT3",
            "SPC-130",
            "SPC-630_256",
            "SPC-630_4096",
            "PHOTON-HDF5",
            "CZ-RAW",
            "SM"
          ],
          "description": "Container format type. Inferred if omitted."
        }
      },
      "outputs": {
        "tttr": {
          "artifact_type": "TTTRRef"
        }
      }
    },
    "tttrlib.TTTR.header": {
      "summary": "Extract metadata header as JSON",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "outputs": {
        "header": {
          "artifact_type": "NativeOutputRef",
          "format": "json"
        }
      }
    },
    "tttrlib.TTTR.get_time_window_ranges": {
      "summary": "Burst selection based on count rate",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "minimum_window_length": {
          "type": "number",
          "required": true,
          "description": "Minimum burst duration in seconds"
        },
        "maximum_window_length": {
          "type": "number",
          "required": false,
          "description": "Maximum burst duration in seconds"
        },
        "minimum_number_of_photons_in_time_window": {
          "type": "integer",
          "required": true,
          "description": "Minimum photons per burst"
        },
        "maximum_number_of_photons_in_time_window": {
          "type": "integer",
          "required": false
        },
        "invert": {
          "type": "boolean",
          "default": false
        }
      },
      "outputs": {
        "ranges": {
          "artifact_type": "TableRef",
          "columns": [
            "start_index",
            "stop_index"
          ]
        }
      }
    },
    "tttrlib.TTTR.get_count_rate": {
      "summary": "Compute scalar count rate from TTTR data",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "outputs": {
        "count_rate": {
          "artifact_type": "NativeOutputRef",
          "format": "json"
        }
      }
    },
    "tttrlib.TTTR.get_intensity_trace": {
      "summary": "Compute intensity trace from TTTR events",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "time_window": {
          "type": "number",
          "required": false,
          "description": "Bin width for trace generation"
        }
      },
      "outputs": {
        "trace": {
          "artifact_type": "TableRef",
          "format": "csv",
          "columns": [
            "time",
            "count_rate"
          ]
        }
      }
    },
    "tttrlib.TTTR.get_selection_by_channel": {
      "summary": "Supported subset for channel-based event selection",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "channels": {
          "type": "array",
          "required": true,
          "items": {
            "type": "integer"
          },
          "description": "Routing channels to include"
        }
      },
      "outputs": {
        "selection": {
          "artifact_type": "TableRef",
          "format": "csv",
          "columns": [
            "index",
            "selected"
          ]
        }
      }
    },
    "tttrlib.TTTR.get_selection_by_count_rate": {
      "summary": "Supported subset for count-rate-based event selection",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "minimum_window_length": {
          "type": "number",
          "required": true
        },
        "maximum_window_length": {
          "type": "number",
          "required": false
        },
        "minimum_number_of_photons_in_time_window": {
          "type": "integer",
          "required": true
        },
        "maximum_number_of_photons_in_time_window": {
          "type": "integer",
          "required": false
        }
      },
      "outputs": {
        "selection": {
          "artifact_type": "TableRef",
          "format": "csv",
          "columns": [
            "index",
            "selected"
          ]
        }
      }
    },
    "tttrlib.TTTR.get_tttr_by_selection": {
      "summary": "Supported subset that creates TTTR subset from boolean selection list",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "selection": {
          "type": "array",
          "required": true,
          "items": {
            "type": "boolean"
          }
        }
      },
      "outputs": {
        "tttr": {
          "artifact_type": "TTTRRef"
        }
      }
    },
    "tttrlib.Correlator": {
      "summary": "Multi-tau correlation analysis",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "channels": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "required": true,
          "description": "[[ch1_list], [ch2_list]] for cross-correlation"
        },
        "n_bins": {
          "type": "integer",
          "default": 17
        },
        "n_casc": {
          "type": "integer",
          "default": 25
        },
        "make_fine": {
          "type": "boolean",
          "default": false
        },
        "method": {
          "type": "string",
          "enum": [
            "wahl",
            "felekyan",
            "laurence"
          ],
          "default": "wahl"
        }
      },
      "outputs": {
        "curve": {
          "artifact_type": "TableRef",
          "columns": [
            "tau",
            "correlation"
          ]
        }
      }
    },
    "tttrlib.CLSMImage": {
      "summary": "Construct scanning image from TTTR data",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "reading_routine": {
          "type": "string",
          "enum": [
            "default",
            "SP5",
            "SP8",
            "BH_SPC130"
          ],
          "default": "default"
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "fill": {
          "type": "boolean",
          "default": true
        },
        "n_pixel_per_line": {
          "type": "integer",
          "required": false
        },
        "n_lines": {
          "type": "integer",
          "required": false
        },
        "n_frames": {
          "type": "integer",
          "required": false
        },
        "marker_frame_start": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "required": false
        },
        "marker_line_start": {
          "type": "integer",
          "required": false
        },
        "marker_line_stop": {
          "type": "integer",
          "required": false
        },
        "skip_before_first_frame_marker": {
          "type": "boolean",
          "default": true
        }
      },
      "outputs": {
        "clsm": {
          "artifact_type": "ObjectRef",
          "python_class": "tttrlib.CLSMImage"
        }
      }
    },
    "tttrlib.CLSMImage.compute_ics": {
      "summary": "Image Correlation Spectroscopy on scanning image",
      "inputs": {
        "clsm": {
          "artifact_type": "ObjectRef",
          "required": true
        }
      },
      "params": {
        "x_range": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "default": [
            0,
            -1
          ]
        },
        "y_range": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "default": [
            0,
            -1
          ]
        },
        "subtract_average": {
          "type": "string",
          "enum": [
            "frame",
            "stack",
            ""
          ],
          "default": "frame"
        },
        "include_summary": {
          "type": "boolean",
          "default": false
        }
      },
      "outputs": {
        "ics": {
          "artifact_type": "BioImageRef"
        },
        "summary": {
          "artifact_type": "TableRef",
          "required": false
        }
      }
    },
    "tttrlib.CLSMImage.get_intensity": {
      "summary": "Extract intensity image from CLSM data",
      "inputs": {
        "clsm": {
          "artifact_type": "ObjectRef",
          "required": true
        }
      },
      "params": {
        "stack_frames": {
          "type": "boolean",
          "default": false,
          "description": "Sum intensity across all frames into a single 2D image"
        }
      },
      "outputs": {
        "intensity": {
          "artifact_type": "BioImageRef",
          "format": "OME-TIFF",
          "description": "3D array (Z,Y,X) or 2D (Y,X) if stack_frames=true"
        }
      }
    },
    "tttrlib.CLSMImage.get_phasor": {
      "summary": "Compute phasor coordinates (g, s) per pixel",
      "inputs": {
        "clsm": {
          "artifact_type": "ObjectRef",
          "required": true
        },
        "tttr_data": {
          "artifact_type": "TTTRRef",
          "required": true,
          "description": "Original TTTR data for microtime access"
        },
        "tttr_irf": {
          "artifact_type": "TTTRRef",
          "required": false,
          "description": "IRF data for correction"
        }
      },
      "params": {
        "frequency": {
          "type": "number",
          "default": -1.0,
          "description": "Modulation frequency in MHz. -1 to auto-detect from header"
        },
        "minimum_number_of_photons": {
          "type": "integer",
          "default": 2,
          "description": "Minimum photons per pixel for valid phasor"
        },
        "stack_frames": {
          "type": "boolean",
          "default": false,
          "description": "Combine frames before phasor calculation"
        }
      },
      "outputs": {
        "phasor": {
          "artifact_type": "BioImageRef",
          "format": "OME-TIFF",
          "description": "Phasor image with channels [g, s] stored on the leading C axis (CYX or CZYX)."
        }
      }
    },
    "tttrlib.CLSMImage.get_fluorescence_decay": {
      "summary": "Extract fluorescence decay histogram per pixel",
      "inputs": {
        "clsm": {
          "artifact_type": "ObjectRef",
          "required": true
        },
        "tttr_data": {
          "artifact_type": "TTTRRef",
          "required": true,
          "description": "Original TTTR data for microtime access"
        }
      },
      "params": {
        "micro_time_coarsening": {
          "type": "integer",
          "default": 1,
          "description": "Factor to coarsen microtime bins (reduce memory)"
        },
        "stack_frames": {
          "type": "boolean",
          "default": false,
          "description": "Combine frames before extraction"
        }
      },
      "outputs": {
        "decay": {
          "artifact_type": "BioImageRef",
          "format": "OME-TIFF",
          "description": "Microtime-bin histogram image. Stored as OME-TIFF with bins on the leading T axis (TYX or TZYX)."
        }
      }
    },
    "tttrlib.CLSMImage.get_mean_lifetime": {
      "summary": "Compute mean fluorescence lifetime per pixel",
      "inputs": {
        "clsm": {
          "artifact_type": "ObjectRef",
          "required": true
        },
        "tttr_data": {
          "artifact_type": "TTTRRef",
          "required": true,
          "description": "Original TTTR data for microtime access"
        },
        "tttr_irf": {
          "artifact_type": "TTTRRef",
          "required": false,
          "description": "IRF data for deconvolution"
        }
      },
      "params": {
        "minimum_number_of_photons": {
          "type": "integer",
          "default": 3,
          "description": "Minimum photons per pixel for valid lifetime"
        },
        "stack_frames": {
          "type": "boolean",
          "default": false,
          "description": "Combine frames before calculation"
        }
      },
      "outputs": {
        "lifetime": {
          "artifact_type": "BioImageRef",
          "format": "OME-TIFF",
          "description": "Mean lifetime image in nanoseconds"
        }
      }
    },
    "tttrlib.TTTR.write": {
      "summary": "Export TTTR data to file under work_dir",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "filename": {
          "type": "string",
          "required": true,
          "description": "Output path"
        }
      },
      "outputs": {
        "tttr_out": {
          "artifact_type": "TTTRRef"
        }
      }
    },
    "tttrlib.TTTR.write_header": {
      "summary": "Write TTTR header to file under work_dir",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "filename": {
          "type": "string",
          "required": true,
          "description": "Output path"
        }
      },
      "outputs": {
        "tttr_out": {
          "artifact_type": "TTTRRef"
        }
      }
    },
    "tttrlib.TTTR.write_hht3v2_events": {
      "summary": "Write HHT3v2 events to .ht3 file under work_dir",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "filename": {
          "type": "string",
          "required": true,
          "description": "Output path"
        }
      },
      "outputs": {
        "tttr_out": {
          "artifact_type": "TTTRRef"
        }
      }
    },
    "tttrlib.TTTR.write_spc132_events": {
      "summary": "Write SPC132 events to .spc file under work_dir",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "filename": {
          "type": "string",
          "required": true,
          "description": "Output path"
        }
      },
      "outputs": {
        "tttr_out": {
          "artifact_type": "TTTRRef"
        }
      }
    },
    "tttrlib.Correlator.get_curve": {
      "summary": "Supported subset returning tau/correlation curve table",
      "inputs": {
        "tttr": {
          "artifact_type": "TTTRRef",
          "required": true
        }
      },
      "params": {
        "channels": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "required": true,
          "description": "[[ch1_list], [ch2_list]] for cross-correlation"
        },
        "n_bins": {
          "type": "integer",
          "default": 17
        },
        "n_casc": {
          "type": "integer",
          "default": 25
        },
        "make_fine": {
          "type": "boolean",
          "default": false
        },
        "method": {
          "type": "string",
          "enum": [
            "wahl",
            "felekyan",
            "laurence"
          ],
          "default": "wahl"
        }
      },
      "outputs": {
        "curve": {
          "artifact_type": "TableRef",
          "format": "csv",
          "columns": [
            "tau",
            "correlation"
          ]
        }
      }
    },
